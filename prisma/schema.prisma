generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CUSTOMER
  SELLER_PENDING
  SELLER_ACTIVE
  ADMIN
}

enum SellerApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SellerKind {
  WHOLESALE_STORE
  INFLUENCER
  BRAND
  HYBRID
}

enum SocialChannelType {
  INSTAGRAM
  YOUTUBE
  TIKTOK
  NAVER_BLOG
  OTHER
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  ENDED
  ARCHIVED
}

enum CommissionSettlementStatus {
  PENDING
  PAYABLE
  SETTLED
  CANCELLED
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  COMPLETED
  CANCELLED
  REFUND_REQUESTED
  RETURN_STARTED
  RETURN_REJECTED
  REFUNDED
  FAILED
  EXPIRED
}

enum PaymentStatus {
  READY
  CONFIRMED
  DONE
  FAILED
  CANCELED
}

enum ProductImageKind {
  MAIN
  CONTENT
}

enum ProductPostType {
  SALE
  ARCHIVE
}

enum DiscountType {
  PERCENT
  FIXED
}

model User {
  id        String   @id @default(cuid())
  email     String?  @unique
  phone     String?  @unique
  name      String?
  password  String?  // ID/PW 로그인 쓸 때만(해시 저장)
  provider  String?  @default("email") // "email" | "kakao" | "naver"
  kakaoId   String?  @unique   // 카카오 고유 ID
  naverId   String?  @unique   // 네이버 고유 ID
  role      UserRole @default(CUSTOMER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sellerProfile SellerProfile?
  products      Product[]      @relation("SellerProducts")
  orders        Order[]        @relation("BuyerOrders")
  addresses     Address[]
  cartItems     CartItem[]

  salesOrders   Order[] @relation("SellerOrders")

  // Follow relationships
  following     SellerFollow[] @relation("UserFollowing")
  followers     SellerFollow[] @relation("UserFollowers")

  reviews       Review[]
  inquiries     Inquiry[]
  coupons       UserCoupon[]
  wishlistItems  Wishlist[]
  notifications  Notification[]
  hiddenProducts HiddenProduct[]
  buyerChats     ChatRoom[] @relation("BuyerChats")
  sellerChats    ChatRoom[] @relation("SellerChats")
  userAttribution UserAttribution?
  campaigns       Campaign[]        @relation("SellerCampaigns")
  referralVisits  CampaignVisit[]   @relation("CampaignVisitSeller")
  referredOrders  OrderAttribution[] @relation("OrderAttributionReferrer")
  commissionOrders OrderCommission[] @relation("OrderCommissionBeneficiary")
  adminActionLogs AdminActionLog[]  @relation("AdminActionLogActor")
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  variantId String
  quantity  Int

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, variantId])
  @@index([userId])
}

model Address {
  id        String   @id @default(cuid())
  userId    String
  name      String
  phone     String
  zipCode   String
  addr1     String
  addr2     String?
  isDefault Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SellerProfile {
  id             String               @id @default(cuid())
  userId         String               @unique
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  shopName       String
  storeSlug      String?              @unique
  sellerKind     SellerKind           @default(WHOLESALE_STORE)
  type           String?              // 여성/남성/혼합 (MVP는 string)
  marketBuilding String?              // 상가명
  floor          String?              // 층
  roomNo         String?              // 호수
  creatorSlug    String?              @unique
  socialChannelType SocialChannelType?
  socialChannelUrl  String?
  followerCount     Int?
  isBusinessSeller  Boolean           @default(true)
  commissionRateBps Int               @default(1000)

  managerName    String?
  managerPhone   String?
  instagramHandle String?            @db.VarChar(80)  // 브랜드 확인용 인스타그램 계정

  taxType        String?              @db.VarChar(20)  // SIMPLIFIED(간이과세자) | GENERAL_CORP(일반/법인)
  bizName        String?              @db.VarChar(80)  // 상호명 (사업자등록증상)
  bizOwnerName   String?              @db.VarChar(40)  // 대표자명
  bizRegNo       String?              // 사업자등록번호 (전자상거래법 표시용)
  bizRegImageUrl String?              // S3 URL
  mailOrderReportImageUrl String?     // 통신판매업 신고증 이미지
  passbookImageUrl String?            // 정산 통장 사본 이미지
  bizRegSubmittedAt DateTime?         // 사업자 정보 제출 시점
  avatarUrl      String?              // Profile avatar URL
  bio            String?              @db.VarChar(160) // 소개글 160자
  locationText   String?              @db.VarChar(60)  // 위치 표시용 텍스트 (예: "동대문 · A층 · 101")
  csEmail        String?              // Customer service email for contact
  csPhone        String?              @db.VarChar(30)  // CS 전화번호
  csKakaoId      String?              // CS 카카오톡 ID
  csAddress      String?              // CS/교환/반품 주소
  csHours        String?              @db.VarChar(40)  // CS 운영시간 (예: "평일 10-18시")
  shippingGuide  String?              @db.Text         // 배송 안내
  exchangeGuide  String?              @db.Text         // 교환/반품 안내
  refundGuide    String?              @db.Text         // 환불 안내
  etcGuide       String?              @db.Text         // 기타 안내
  settlementBank String?              @db.VarChar(40)  // 정산 은행
  settlementAccountNo String?         @db.VarChar(60)  // 정산 계좌번호
  settlementAccountHolder String?     @db.VarChar(40)  // 정산 예금주
  settlementPhone String?             @db.VarChar(30)  // 정산용 휴대폰
  settlementEmail String?             // 정산용 이메일
  settlementSubmittedAt DateTime?     // 정산 계좌 제출 시점
  complianceReviewPending Boolean      @default(false) // 사업자/정산 정보 변경 검토 필요 여부
  status         SellerApprovalStatus @default(PENDING)
  rejectedReason String?

  shippingFeeKrw        Int @default(3000)
  freeShippingThreshold Int @default(50000)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  slugHistory    StoreSlugHistory[]
}

model StoreSlugHistory {
  id              String        @id @default(cuid())
  sellerProfileId String
  sellerProfile   SellerProfile @relation(fields: [sellerProfileId], references: [id], onDelete: Cascade)
  slug            String        @unique
  createdAt       DateTime      @default(now())

  @@index([sellerProfileId, createdAt])
}

model Product {
  id          String        @id @default(cuid())
  sellerId    String
  seller      User          @relation("SellerProducts", fields: [sellerId], references: [id], onDelete: Cascade)

  title       String
  description String?       // Legacy plain text description (kept for backward compatibility)
  descriptionJson Json?     // Structured description (v1: spec, detail, csShipping)
  category    String?       // DEPRECATED: 기존 카테고리 (유지, 사용 안 함)
  postType    ProductPostType @default(SALE)

  // 3-Depth Category Structure (여성의류/남성의류)
  categoryMain String?      // 여성의류 / 남성의류
  categoryMid  String?      // 상의 / 하의 / 원피스 / 아우터 등
  categorySub  String?      // 티셔츠 / 데님 / 미니원피스 등

  priceKrw      Int
  salePriceKrw  Int?           // 할인가 (null이면 할인 없음)
  sortOrder     Int            @default(0) // 셀러별 상품 정렬 순서 (낮을수록 앞)
  isActive    Boolean       @default(true)
  isDeleted   Boolean       @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  images      ProductImage[]
  variants    ProductVariant[]
  orderItems  OrderItem[]
  reviews     Review[]
  inquiries   Inquiry[]
  wishlistItems  Wishlist[]
  hiddenByUsers  HiddenProduct[]
  campaignProducts CampaignProduct[]

  @@index([categoryMain, categoryMid, categorySub])
  @@index([sellerId])
  @@index([postType, isActive, isDeleted])
  @@index([isActive, isDeleted])
  @@index([createdAt])
}

model ProductImage {
  id        String           @id @default(cuid())
  productId String
  product   Product          @relation(fields: [productId], references: [id], onDelete: Cascade)

  url       String
  kind      ProductImageKind @default(MAIN)
  sortOrder Int              @default(0)
  colorKey  String?          // 색상별 이미지 설정용 (정규화된 색상명)

  createdAt DateTime @default(now())
}

model ProductVariant {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  color          String @default("FREE")
  sizeLabel      String @default("FREE")
  stock          Int    @default(0)
  priceAddonKrw  Int    @default(0)
  sku            String? @unique

  orderItems OrderItem[] @relation("VariantOrderItems")
  cartItems  CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, color, sizeLabel])
  @@index([productId])
}

model Order {
  id           String      @id @default(cuid())
  orderNo      String      @unique // 표시용 주문번호
  status       OrderStatus @default(PENDING)

  buyerId      String
  buyer        User        @relation("BuyerOrders", fields: [buyerId], references: [id], onDelete: Restrict)

  sellerId     String
  seller       User        @relation("SellerOrders", fields: [sellerId], references: [id], onDelete: Restrict)

  totalAmountKrw   Int
  itemsSubtotalKrw Int @default(0)
  shippingFeeKrw   Int @default(0)
  totalPayKrw      Int @default(0)

  shipToName   String?
  shipToPhone  String?
  shipToZip    String?
  shipToAddr1  String?
  shipToAddr2  String?
  shipToMemo   String?

  // Idempotency key for checkout flow
  checkoutAttemptId String? @unique

  expiresAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  items        OrderItem[]
  payment      Payment?
  shipment     Shipment?
  attribution  OrderAttribution?
  commission   OrderCommission?
  claims       OrderClaim[]

  @@index([buyerId])
  @@index([sellerId])
  @@index([sellerId, status])
  @@index([createdAt])
}

model OrderItem {
  id         String  @id @default(cuid())
  orderId    String
  order      Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId  String
  product    Product @relation(fields: [productId], references: [id], onDelete: Restrict)

    variantId  String?
  variant    ProductVariant? @relation("VariantOrderItems", fields: [variantId], references: [id], onDelete: SetNull)

  quantity   Int     @default(1)
  unitPriceKrw Int

  createdAt  DateTime @default(now())

  @@index([orderId])
  @@index([productId])
}

model Payment {
  id          String        @id @default(cuid())
  orderId     String        @unique
  order       Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)

  paymentKey  String?       @unique // Toss paymentKey (확정되면 저장)
  status      PaymentStatus @default(READY)
  method      String?
  amountKrw   Int
  mode        String?       @db.VarChar(8) // "live" | "test" — 결제 시작 시점 모드 고정
  rawResponse Json?

  approvedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Shipment {
  id         String   @id @default(cuid())
  orderId    String   @unique
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  courier    String?
  trackingNo String?
  shippedAt  DateTime?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

enum OrderClaimType {
  REFUND   // 환불
  EXCHANGE // 교환
}

enum OrderClaimReason {
  CHANGED_MIND      // 단순변심 (왕복배송비 구매자 부담, 자동승인)
  DEFECT            // 상품 하자
  WRONG_ITEM        // 오배송
  DAMAGED_DELIVERY  // 배송 중 파손
  OTHER             // 기타
}

enum OrderClaimStatus {
  REQUESTED   // 신청
  APPROVED    // 셀러 승인 (또는 단순변심 자동 승인)
  REJECTED    // 셀러 반려
  COMPLETED   // 처리 완료 (환불/교환 완료)
  CANCELLED   // 사용자 취소
}

model OrderClaim {
  id        String           @id @default(cuid())
  orderId   String
  order     Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)

  type      OrderClaimType
  reason    OrderClaimReason
  status    OrderClaimStatus @default(REQUESTED)

  message       String? // 사용자 사유 메시지
  photoUrls     String[] @default([]) // 하자/오배송 증빙 사진
  sellerResponse String? // 셀러 응답/반려 사유

  // 단순변심 등 구매자 부담 비용 (왕복배송비 환불액 차감)
  buyerBurdenKrw Int @default(0)
  // 실제 환불 금액 (totalPayKrw - buyerBurdenKrw)
  refundAmountKrw Int @default(0)

  decidedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([orderId])
  @@index([status])
  @@index([createdAt])
}

model OrderAuditLog {
  id        String      @id @default(cuid())
  orderId   String
  adminId   String
  from      OrderStatus
  to        OrderStatus
  reason    String
  createdAt DateTime    @default(now())

  @@index([orderId])
  @@index([adminId])
}

model AppSetting {
  key       String   @id @db.VarChar(80)
  value     Json
  updatedAt DateTime @updatedAt
  updatedBy String?
}

model AdminActionLog {
  id        String   @id @default(cuid())
  adminId   String
  admin     User     @relation("AdminActionLogActor", fields: [adminId], references: [id], onDelete: Restrict)
  entityType String  @db.VarChar(40)
  entityId   String
  action     String  @db.VarChar(80)
  summary    String  @db.Text
  reason     String? @db.Text
  beforeJson Json?
  afterJson  Json?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId, createdAt])
  @@index([adminId, createdAt])
}

model SellerFollow {
  id         String   @id @default(cuid())
  followerId String   // User.id (누가)
  sellerId   String   // User.id (누구를 - 판매자)

  follower   User     @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  seller     User     @relation("UserFollowers", fields: [sellerId], references: [id], onDelete: Cascade)

  createdAt  DateTime @default(now())

  @@unique([followerId, sellerId])
  @@index([sellerId])
  @@index([followerId])
}

model Review {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItemId String   @unique
  rating      Int      // 1-5
  content     String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, orderItemId])
  @@index([productId])
  @@index([userId])
}

model Inquiry {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  question    String    @db.Text
  answer      String?   @db.Text
  answeredBy  String?   // seller userId
  answeredAt  DateTime?
  isSecret    Boolean   @default(false) // 비밀글

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([productId])
  @@index([userId])
}

model Coupon {
  id                String       @id @default(cuid())
  code              String       @unique
  name              String
  discountType      DiscountType
  discountValue     Int          // 퍼센트(1-100) 또는 원단위
  minOrderAmount    Int?         // 최소 주문 금액
  maxDiscountAmount Int?         // 최대 할인 금액 (PERCENT일 때)
  totalCount        Int?         // 총 발급 가능 수 (null=무제한)
  isActive          Boolean      @default(true)
  expiresAt         DateTime?
  createdAt         DateTime     @default(now())

  userCoupons       UserCoupon[]
  campaigns         Campaign[]
}

model Campaign {
  id                       String        @id @default(cuid())
  sellerId                 String
  seller                   User          @relation("SellerCampaigns", fields: [sellerId], references: [id], onDelete: Cascade)
  title                    String
  slug                     String        @unique
  description              String?       @db.Text
  coverImageUrl            String?
  landingHeadline          String?
  landingBody              String?       @db.Text
  couponId                 String?
  coupon                   Coupon?       @relation(fields: [couponId], references: [id], onDelete: SetNull)
  refCode                  String        @unique
  status                   CampaignStatus @default(DRAFT)
  startsAt                 DateTime?
  endsAt                   DateTime?
  defaultCommissionRateBps Int?
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt

  products         CampaignProduct[]
  visits           CampaignVisit[]
  userAttributions UserAttribution[]
  orderAttributions OrderAttribution[]
  orderCommissions  OrderCommission[]

  @@index([sellerId, status])
  @@index([startsAt, endsAt])
}

model CampaignProduct {
  id         String   @id @default(cuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  @@unique([campaignId, productId])
  @@index([campaignId, sortOrder])
  @@index([productId])
}

model CampaignVisit {
  id          String    @id @default(cuid())
  campaignId   String?
  campaign     Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  sellerId     String?
  seller       User?     @relation("CampaignVisitSeller", fields: [sellerId], references: [id], onDelete: SetNull)
  refCode      String?
  creatorSlug  String?
  utmSource    String?
  utmMedium    String?
  utmCampaign  String?
  landingPath  String?
  sessionKey   String?
  createdAt    DateTime @default(now())

  @@index([campaignId, createdAt])
  @@index([sellerId, createdAt])
}

model UserAttribution {
  id            String    @id @default(cuid())
  userId         String    @unique
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaignId     String?
  campaign       Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  refCode        String?
  creatorSlug    String?
  utmSource      String?
  utmMedium      String?
  utmCampaign    String?
  landingPath    String?
  firstTouchedAt DateTime?
  lastTouchedAt  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([campaignId])
}

model OrderAttribution {
  id            String    @id @default(cuid())
  orderId        String    @unique
  order          Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  campaignId     String?
  campaign       Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  referrerUserId String?
  referrerUser   User?     @relation("OrderAttributionReferrer", fields: [referrerUserId], references: [id], onDelete: SetNull)
  refCode        String?
  creatorSlug    String?
  utmSource      String?
  utmMedium      String?
  utmCampaign    String?
  landingPath    String?
  firstTouchedAt DateTime?
  lastTouchedAt  DateTime?
  createdAt      DateTime  @default(now())

  @@index([campaignId])
  @@index([referrerUserId])
}

model OrderCommission {
  id                 String                     @id @default(cuid())
  orderId            String                     @unique
  order              Order                      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  beneficiaryUserId  String?
  beneficiaryUser    User?                      @relation("OrderCommissionBeneficiary", fields: [beneficiaryUserId], references: [id], onDelete: SetNull)
  campaignId         String?
  campaign           Campaign?                  @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  commissionRateBps  Int
  commissionBaseKrw  Int
  commissionAmountKrw Int
  status             CommissionSettlementStatus @default(PENDING)
  payableAt          DateTime?
  settledAt          DateTime?
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt

  @@index([beneficiaryUserId, status])
  @@index([campaignId, status])
}

model UserCoupon {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  couponId  String
  coupon    Coupon    @relation(fields: [couponId], references: [id], onDelete: Cascade)
  usedAt    DateTime?
  orderId   String?
  createdAt DateTime  @default(now())

  @@unique([userId, couponId])
  @@index([userId])
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // ORDER_STATUS, REVIEW, INQUIRY_ANSWER, COUPON 등
  title     String
  body      String?
  isRead    Boolean  @default(false)
  link      String?  // 클릭 시 이동할 경로
  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

model HiddenProduct {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
}

enum ChatRoomStatus {
  ACTIVE
  CLOSED
}

enum ChatSenderType {
  BUYER
  SELLER
  SYSTEM
}

model ChatRoom {
  id                String         @id @default(cuid())
  buyerId           String
  buyer             User           @relation("BuyerChats", fields: [buyerId], references: [id])
  sellerId          String
  seller            User           @relation("SellerChats", fields: [sellerId], references: [id])
  status            ChatRoomStatus @default(ACTIVE)
  lastMessageAt     DateTime?
  closedAt          DateTime?
  externalChannelId String?
  createdAt         DateTime       @default(now())

  messages          ChatMessage[]

  @@unique([buyerId, sellerId])
  @@index([buyerId, status])
  @@index([sellerId, status])
}

model ChatMessage {
  id             String         @id @default(cuid())
  roomId         String
  room           ChatRoom       @relation(fields: [roomId], references: [id], onDelete: Cascade)
  senderId       String
  senderType     ChatSenderType
  content        String?        @db.Text
  imageUrl       String?
  isRead         Boolean        @default(false)
  readAt         DateTime?
  channel        String         @default("INTERNAL")
  relatedOrderId String?
  createdAt      DateTime       @default(now())

  @@index([roomId, createdAt])
  @@index([roomId, isRead])
}
